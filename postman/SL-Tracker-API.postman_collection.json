      "item": [
        {
          "name": "Get Avatar Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/avatar/12345678-1234-1234-1234-123456789012/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "avatar", "12345678-1234-1234-1234-123456789012", "profile"]
            },
            "description": "Fetch fresh profile from Second Life"
          }
        },
        {
          "name": "Get Avatar Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/avatar/12345678-1234-1234-1234-123456789012",
              "host": ["{{baseUrl}}"],
              "path": ["api", "avatar", "12345678-1234-1234-1234-123456789012"]
            },
            "description": "Get avatar stats, hourly histogram, visit history"
          }
        },
        {
          "name": "Active Reminders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/reminders/active",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reminders", "active"]
            },
            "description": "List all active reminders with overdue status"
          }
        }
      ]
    },
