              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Avatar key matches', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.avatarKey).to.eql('87654321-4321-4321-4321-210987654321');",
                  "});"
