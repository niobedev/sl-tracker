{
  "info": {
    "name": "SL Tracker API",
    "description": "API collection for Second Life Tracker - Avatar tracking and notifications system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "your-api-secret-key",
      "type": "string"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "X-API-Key",
        "in": "header"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login Page",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Get the login page"
          }
        }
      ]
    },
    {
      "name": "Public Analytics",
      "item": [
        {
          "name": "Live Visitors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/live-visitors",
              "host": ["{{baseUrl}}"],
              "path": ["api", "live-visitors"]
            },
            "description": "Get currently online visitors"
          }
        },
        {
          "name": "Recent Visitors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/recent-visitors?period=today",
              "host": ["{{baseUrl}}"],
              "path": ["api", "recent-visitors"],
              "query": [
                {
                  "key": "period",
                  "value": "today",
                  "description": "today, yesterday, week, month, year, all"
                }
              ]
            },
            "description": "Get visitors for a time period"
          }
        },
        {
          "name": "Leaderboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/leaderboard?limit=25",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leaderboard"],
              "query": [
                {
                  "key": "limit",
                  "value": "25",
                  "description": "Max number of results"
                }
              ]
            },
            "description": "Get top visitors by visit count"
          }
        },
        {
          "name": "Heatmap",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/heatmap",
              "host": ["{{baseUrl}}"],
              "path": ["api", "heatmap"]
            },
            "description": "Get activity heatmap by day/hour"
          }
        },
        {
          "name": "Hourly Activity",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/hourly",
              "host": ["{{baseUrl}}"],
              "path": ["api", "hourly"]
            },
            "description": "Get hourly activity histogram"
          }
        },
        {
          "name": "Daily Statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/daily",
              "host": ["{{baseUrl}}"],
              "path": ["api", "daily"]
            },
            "description": "Get daily statistics"
          }
        },
        {
          "name": "Weekday Statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/weekday",
              "host": ["{{baseUrl}}"],
              "path": ["api", "weekday"]
            },
            "description": "Get day-of-week statistics"
          }
        },
        {
          "name": "Concurrent Presence",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/concurrent?days=90",
              "host": ["{{baseUrl}}"],
              "path": ["api", "concurrent"],
              "query": [
                {
                  "key": "days",
                  "value": "90",
                  "description": "Lookback period in days"
                }
              ]
            },
            "description": "Get concurrent presence data"
          }
        },
        {
          "name": "Duration Distribution",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/duration-distribution",
              "host": ["{{baseUrl}}"],
              "path": ["api", "duration-distribution"]
            },
            "description": "Get visit duration distribution"
          }
        },
        {
          "name": "Frequency vs Duration",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/frequency-vs-duration",
              "host": ["{{baseUrl}}"],
              "path": ["api", "frequency-vs-duration"]
            },
            "description": "Get visit frequency vs duration correlation"
          }
        },
        {
          "name": "New vs Returning",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/new-vs-returning",
              "host": ["{{baseUrl}}"],
              "path": ["api", "new-vs-returning"]
            },
            "description": "Get new vs returning visitors breakdown"
          }
