{% extends 'base.html.twig' %}

{% block title %}Avatar Management{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Avatar Management</h1>
            <p class="text-gray-600 dark:text-gray-400 mt-2">Manage tracked avatars and configure notifications</p>
        </div>
        <button onclick="showAddModal()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors">
            Add Avatar
        </button>
    </div>

    <!-- Avatar List -->
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
            <thead class="bg-gray-50 dark:bg-gray-900">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Avatar</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Notification</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Added</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                {% for item in avatars %}
                {% set avatar = item.avatar %}
                {% set profile = item.profile %}
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center">
                            {% if profile and profile.imageUrl %}
                            <img src="{{ path('app_avatar_picture', {key: avatar.avatarKey}) }}" 
                                 class="h-10 w-10 rounded-full object-cover"
                                 alt="{{ profile.name|default(avatar.avatarKey) }}"
                                 onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22%236b7280%22><path d=%22M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z%22/></svg>'">
                            {% else %}
                            <div class="h-10 w-10 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
                                <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                                </svg>
                            </div>
                            {% endif %}
                            <div class="ml-4">
                                <div class="text-sm font-medium text-gray-900 dark:text-white">
                                    {{ profile.name|default(avatar.avatarKey) }}
                                </div>
                                <div class="text-sm text-gray-500 dark:text-gray-400">
                                    {{ profile.username|default('No username') }}
                                </div>
                                <div class="text-xs text-gray-400 dark:text-gray-500 font-mono">
                                    {{ avatar.avatarKey }}
                                </div>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <button onclick="toggleTracking('{{ avatar.avatarKey }}', {{ avatar.trackingEnabled ? 'false' : 'true' }})"
                                class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 {{ avatar.trackingEnabled ? 'bg-indigo-600' : 'bg-gray-200 dark:bg-gray-600' }}">
                            <span class="sr-only">Use setting</span>
                            <span class="pointer-events-none relative inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out {{ avatar.trackingEnabled ? 'translate-x-5' : 'translate-x-0' }}">
                            </span>
                        </button>
                        <span class="ml-2 text-sm {{ avatar.trackingEnabled ? 'text-green-600 dark:text-green-400' : 'text-gray-500 dark:text-gray-400' }}">
                            {{ avatar.trackingEnabled ? 'Tracking' : 'Disabled' }}
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <select onchange="setChannel('{{ avatar.avatarKey }}', this.value)"
                                class="text-sm border-gray-300 dark:border-gray-600 dark:bg-gray-700 rounded-md focus:ring-indigo-500 focus:border-indigo-500">
                            <option value="">None</option>
                            {% for channel in channels %}
                            <option value="{{ channel.id }}" {% if avatar.notificationChannel and avatar.notificationChannel.id == channel.id %}selected{% endif %}>
                                {{ channel.name }} ({{ channel.type }})
                            </option>
                            {% endfor %}
                        </select>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                        <time datetime="{{ avatar.createdAt|date('Y-m-d\\TH:i:s\\Z') }}" data-local>
                            {{ avatar.createdAt|date('Y-m-d H:i') }}
                        </time>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <a href="{{ path('app_avatar', {key: avatar.avatarKey}) }}" 
                           class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300">
                            View Details
                        </a>
                        <button type="button" onclick="deleteAvatar('{{ avatar.avatarKey }}')"
                                class="ml-4 text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300">
                            Delete
                        </button>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                        </svg>
                        <h3 class="mt-2 text-sm font-medium text-gray-900 dark:text-white">No avatars tracked</h3>
                        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Get started by adding your first avatar.</p>
                        <div class="mt-6">
                            <button onclick="showAddModal()" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
                                Add Avatar
                            </button>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- Add Avatar Modal -->
<div id="addModal" class="fixed inset-0 bg-gray-500 bg-opacity-75 flex items-center justify-center hidden z-50">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full mx-4">
        <div class="px-4 py-5 sm:p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-medium text-gray-900 dark:text-white">Add Avatar</h3>
                <button onclick="hideAddModal()" class="text-gray-400 hover:text-gray-500">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
            <form id="addAvatarForm">
                <div>
                    <label for="avatarKey" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">
                        Avatar UUID
                    </label>
                    <input type="text" 
                           id="avatarKey" 
                           name="avatarKey"
                           placeholder="12345678-1234-1234-1234-123456789012"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 dark:bg-gray-700 dark:text-white"
                           required
                           pattern="[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}">
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                        Enter the UUID of the avatar you want to track. The system will fetch their profile from Second Life.
                    </p>
                </div>
                <div id="addError" class="mt-2 text-sm text-red-600 hidden"></div>
                <div class="mt-5 sm:mt-6 flex justify-end space-x-3">
                    <button type="button" 
                            onclick="hideAddModal()" 
                            class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                        Cancel
                    </button>
                    <button type="submit" 
                            id="addSubmitBtn"
                            class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700">
                        Add Avatar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function showAddModal() {
    document.getElementById('addModal').classList.remove('hidden');
    document.getElementById('avatarKey').focus();
}

function hideAddModal() {
    document.getElementById('addModal').classList.add('hidden');
    document.getElementById('avatarKey').value = '';
    document.getElementById('addError').classList.add('hidden');
}

document.getElementById('addAvatarForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const avatarKey = document.getElementById('avatarKey').value.trim();
    const errorDiv = document.getElementById('addError');
    const submitBtn = document.getElementById('addSubmitBtn');
    
    errorDiv.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Adding...';
    
    try {
        const response = await fetch('/avatars', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ avatarKey })
        });
        
        const data = await response.json();
        
        if (!response.ok) {
            throw new Error(data.error || 'Failed to add avatar');
        }
        
        hideAddModal();
        window.location.reload();
    } catch (error) {
        errorDiv.textContent = error.message;
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Add Avatar';
    }
});

async function toggleTracking(avatarKey, enabled) {
    try {
        const response = await fetch(`/avatars/${avatarKey}`, {
            method: 'PATCH',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ trackingEnabled: enabled })
        });
        
        if (!response.ok) {
            throw new Error('Failed to update tracking status');
        }
        
        window.location.reload();
    } catch (error) {
        alert('Error: ' + error.message);
    }
}

async function setChannel(avatarKey, channelId) {
    try {
        const response = await fetch(`/avatars/${avatarKey}`, {
            method: 'PATCH',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ notificationChannelId: channelId || null })
        });
        
        if (!response.ok) {
            throw new Error('Failed to update notification channel');
        }
    } catch (error) {
        alert('Error: ' + error.message);
        window.location.reload();
    }
}

async function deleteAvatar(avatarKey) {
    if (!confirm('Are you sure you want to stop tracking this avatar?')) {
        return;
    }
    
    try {
        const response = await fetch(`/api/avatars/${avatarKey}`, {
            method: 'DELETE',
            headers: {
                'X-API-Key': 'toralapikey'
            }
        });
        
        if (!response.ok) {
            const data = await response.json();
            throw new Error(data.error || 'Failed to delete avatar');
        }
        
        window.location.reload();
    } catch (error) {
        alert('Error: ' + error.message);
    }
}
</script>
{% endblock %}
