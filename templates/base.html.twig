<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}ATS{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png">
    <link rel="apple-touch-icon" href="/favicon-192.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        brand: { 500: '#6366f1', 600: '#4f46e5', 700: '#4338ca' }
                    }
                }
            }
        }
    </script>
    <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>

    {% block head %}{% endblock %}
</head>
<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen">

    {% if app.user %}
    <nav class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-3 sticky top-0 z-10">
        <div class="flex items-center justify-between">
            <a href="{{ path('app_dashboard') }}" class="text-lg font-bold tracking-tight text-indigo-500">
                Avatar Tracking System
            </a>
            <div class="flex items-center gap-6 text-sm">
                <a href="{{ path('app_dashboard') }}" class="text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">Dashboard</a>
                <a href="{{ path('app_avatars_index') }}" class="text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">Avatars</a>
                <a href="{{ path('app_notification_channels_index') }}" class="text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">Channels</a>

                <span class="text-gray-500 dark:text-gray-400">{{ app.user.userIdentifier }}</span>
                <a href="{{ path('app_logout') }}" class="text-gray-500 hover:text-red-400 transition-colors">Logout</a>
            </div>
        </div>
    </nav>
    {% endif %}

    <main class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        {% block body %}{% endblock %}
    </main>

    <script type="module" src="/assets/local-time.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
